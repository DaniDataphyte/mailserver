APP_NAME="Dataphyte-Newsletter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Lagos

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Database — MySQL
# ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─────────────────────────────────────────────
# Session, Cache & Queue
# ─────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# local: sync | production: redis
QUEUE_CONNECTION=sync

# local: redis | production: redis
CACHE_STORE=redis
REDIS_CACHE_DB=1
#CACHE_PREFIX=

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
# Production only — set by Cloudways:
# REDIS_PREFIX=
# REDIS_USERNAME=

# ─────────────────────────────────────────────
# Mail — set MAIL_MAILER to 'mailtrap' (local) or 'elasticemail' (production)
# ─────────────────────────────────────────────
MAIL_MAILER=mailtrap
MAIL_FROM_ADDRESS="newsletter@dataphyte.com"
MAIL_FROM_NAME="Dataphyte"

# Mailtrap — local dev only (get from mailtrap.io → Inboxes → SMTP Settings)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# ─────────────────────────────────────────────
# Elastic Email — production
# ─────────────────────────────────────────────
ELASTIC_EMAIL_API_KEY=

# Webhook shared secret (optional — leave blank to skip verification)
ELASTIC_EMAIL_WEBHOOK_SECRET=

# Emails per minute. Rule of thumb: DAILY_LIMIT / 960 (16hr sending window).
# Examples: 1,000/day → 1  |  10,000/day → 10  |  50,000/day → 52
ELASTIC_EMAIL_SEND_RATE=50

# ─────────────────────────────────────────────
# Newsletter — Senders
# ─────────────────────────────────────────────
NEWSLETTER_PHYSICAL_ADDRESS="404 54 Rd, Gwarinpa, 900108, Federal Capital"

NEWSLETTER_INSIGHT_FROM_EMAIL=newsletter@dataphyte.com
NEWSLETTER_INSIGHT_FROM_NAME="Dataphyte Insight"
NEWSLETTER_INSIGHT_REPLY_TO=

NEWSLETTER_FOUNDATION_FROM_EMAIL=newsletter@mail.dataphyte.com
NEWSLETTER_FOUNDATION_FROM_NAME="Dataphyte Foundation"
NEWSLETTER_FOUNDATION_REPLY_TO=

# ─────────────────────────────────────────────
# Analytics Sync
# ─────────────────────────────────────────────

# Job 1 — Recent scan (runs hourly): catches opens/clicks shortly after send
SYNC_RECENT_HOURS=8
SYNC_RECENT_LIMIT=500

# Job 2 — Deep scan (runs daily at 2 AM): catches late opens/clicks over 30 days
SYNC_DEEP_DAYS=30
SYNC_DEEP_LIMIT=2000

# ─────────────────────────────────────────────
# AWS (unused — keep for Laravel default compatibility)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# Statamic
# ─────────────────────────────────────────────
STATAMIC_LICENSE_KEY=
STATAMIC_PRO_ENABLED=true
STATAMIC_STACHE_WATCHER=auto
STATAMIC_STATIC_CACHING_STRATEGY=null
STATAMIC_TWO_FACTOR_ENABLED=true
STATAMIC_REVISIONS_ENABLED=false
STATAMIC_GRAPHQL_ENABLED=false
STATAMIC_API_ENABLED=false
STATAMIC_GIT_ENABLED=false

DEBUGBAR_ENABLED=false

# CP branding logos (path relative to /storage)
STATAMIC_CUSTOM_LOGO_URL=/storage/dataphyte-foundation-logo.png
STATAMIC_CUSTOM_DARK_LOGO_URL=/storage/dataphyte-foundation-logo-2.png
